# Application
API_KEY=dev-api-key-change-me
DEFAULT_TENANT_ID=ph-balta-doamnei
SERVICE_VERSION=1.0.0
ACTIVE_WORKERS=4
LOG_LEVEL=INFO
DOCS_ENABLED=true

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://lex:lex@localhost:5432/scraper

# Cache & state (Redis)
REDIS_URL=redis://redis:6379/0

# Message broker (RabbitMQ)
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# Browser rendering (Playwright)
BROWSER_WORKERS=4

# Webhook HMAC secret (shared out-of-band with caller)
WEBHOOK_SECRET=

# OpenTelemetry (unset = no-op; set in production to export traces/metrics)
OTEL_SERVICE_NAME=lex-advisor-scraper
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=dev